APP_NAME="Double Entry Accounting Tests"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Database Configuration for Testing
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Cache & Session for Testing  
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# Mail for Testing
MAIL_MAILER=array

# Disable external services in tests
PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# Testing-specific configurations
BCRYPT_ROUNDS=4

# Multitenancy settings for tests
TENANCY_MODE=single

# Disable unnecessary features during testing
LOG_CHANNEL=single
LOG_LEVEL=error

# Test database seeding
SEED_TEST_DATA=true